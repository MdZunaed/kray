# Kray blueprint environment template
# Copy this file to `.env.local` for local development.
# Do not commit real secrets.

# App
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Database
# Supabase is used as hosted Postgres only.
# Use the pooled connection for app/runtime access.
DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:6543/postgres?pgbouncer=true&connection_limit=1

# Optional: direct connection for Prisma migrations / studio if your provider recommends it.
DIRECT_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres

# Auth
JWT_SECRET=replace-with-a-long-random-secret

# Store identity
STORE_CODE=kray-default
STORE_NAME=Kray

# Future optional integrations
# PAYMENT_PROVIDER=
# PAYMENT_SECRET_KEY=
# SHIPPING_PROVIDER=
# SHIPPING_API_KEY=
# ANALYTICS_ID=
